# App
DATABASE_URL="postgresql://delivergo:delivergo@localhost:5433/delivergo?schema=public"
# Neon (Vercel): use pooled URL for DATABASE_URL, direct URL for migrations if using Prisma directUrl
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Uber Direct (sandbox credentials from https://direct.uber.com → Developer tab)
UBER_CLIENT_ID=""
UBER_CLIENT_SECRET=""
UBER_CUSTOMER_ID=""
UBER_API_BASE="https://api.uber.com"
# false = sandbox + robo courier on delivery create (default)
UBER_LIVE_MODE="false"
# Optional — defaults to America/Toronto for date/time display
# STORE_TIMEZONE="America/Toronto"
# Webhook signing key from Uber Developer Dashboard → Settings → Ride Requests.
# Falls back to UBER_CLIENT_SECRET when empty.
UBER_WEBHOOK_SIGNING_SECRET=""

# Geocoding (Mapbox — Canada-biased)
MAPBOX_ACCESS_TOKEN=""
